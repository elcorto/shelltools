#!/usr/bin/env python

import argparse
import re
import subprocess
import sys
from dataclasses import dataclass
from datetime import datetime, timezone
from email.utils import getaddresses

VALIDITY_RE = re.compile(
    r"^\s*validity:\s*(\d{4}-\d{2}-\d{2})\s+(\d{2}:\d{2}:\d{2})\s+through\s+"
    r"(\d{4}-\d{2}-\d{2})\s+(\d{2}:\d{2}:\d{2})\s*$"
)
AKA_RE = re.compile(r"^\s*aka:\s*(.+?)\s*$", re.IGNORECASE)
FPR_RE = re.compile(r"^\s*sha\d+\s+fpr:\s*([0-9A-Fa-f:]+)\s*$")


@dataclass
class Cert:
    emails: list[str]
    not_after: datetime
    fpr: str
    raw: list[str]
    is_valid: bool


@dataclass
class Classified:
    keep_email: list[Cert]
    keep_no_aka: list[Cert]
    keep_best_valid: list[Cert]
    keep_best_expired: list[Cert]
    to_delete: list[Cert]
    best_for_fpr: dict[str, list[str]]


def system(cmd: list[str]) -> subprocess.CompletedProcess:
    try:
        proc = subprocess.run(
            cmd,
            text=True,
            check=True,
            stderr=subprocess.STDOUT,
            stdout=subprocess.PIPE,
        )
    except subprocess.CalledProcessError as ex:
        sys.stderr.write(ex.stdout)
        raise SystemExit(ex.returncode)
    return proc


def parse_validity_end(end_date: str, end_time: str) -> datetime:
    end_dt = f"{end_date} {end_time}"
    dt = datetime.strptime(end_dt, "%Y-%m-%d %H:%M:%S")
    return dt.replace(tzinfo=timezone.utc)


def parse_aka_emails(aka_value: str) -> list[str]:
    emails = [addr.lower() for _, addr in getaddresses([aka_value]) if addr]
    return emails


def normalize_email(value: str) -> str:
    parsed = parse_aka_emails(value)
    if parsed:
        return parsed[0]
    return value.strip().lower()


def parse_cert_block(block_lines: list[str], now_utc: datetime) -> Cert:
    emails = []
    not_after = None
    fpr = None
    id_line = None

    for line in block_lines:
        if id_line is None and line.lstrip().startswith("ID:"):
            id_line = line.strip()
        m = AKA_RE.match(line)
        if m:
            emails.extend(parse_aka_emails(m.group(1).strip()))

        m = VALIDITY_RE.match(line)
        if m:
            not_after = parse_validity_end(m.group(3), m.group(4))

        m = FPR_RE.match(line)
        if m and fpr is None:
            fpr = m.group(1).strip()

    if fpr is None:
        details = f" ({id_line})" if id_line else ""
        raise ValueError(f"Missing fingerprint in certificate block{details}")

    if not_after is None:
        details = f" ({id_line})" if id_line else ""
        raise ValueError(f"Missing validity in certificate block{details}")

    emails = list(dict.fromkeys(emails))

    return Cert(
        emails=emails,
        not_after=not_after,
        fpr=fpr,
        raw=block_lines,
        is_valid=not_after >= now_utc,
    )


def parse_gpgsm_certs(now_utc: datetime, keep_email: str) -> list[Cert]:
    stdout = system(["gpgsm", "--list-keys"]).stdout
    certs = []
    current = []
    started = False
    keep_email_found = False
    parsed_email_set = set()

    def process_block(block: list[str]) -> bool:
        if not block:
            return False
        cert = parse_cert_block(block, now_utc)
        parsed_email_set.update(cert.emails)
        certs.append(cert)
        return keep_email in cert.emails

    for line in stdout.splitlines():
        if line.lstrip().startswith("ID:"):
            started = True
            if current:
                keep_email_found |= process_block(current)
                current = []
        if not started:
            continue
        current.append(line)

    if current:
        keep_email_found |= process_block(current)
    if not certs:
        raise ValueError("No certificates found in gpgsm output")
    if not keep_email_found:
        raise ValueError(
            f"Keep email '{keep_email}' not found in {len(parsed_email_set)} parsed email(s)"
        )
    return certs


def delete_cert(fpr: str):
    system(["gpgsm", "--batch", "--yes", "--delete-key", fpr])


def classify_certs(certs: list[Cert], keep_email: str) -> Classified:
    """
    Classify certificates into categories.

    Returns Classified with:
        - keep_email: list of certs for --keep-email
        - keep_no_aka: list of certs without email (safety)
        - keep_best_valid: list of valid certs that are best per recipient
        - keep_best_expired: list of expired certs that are best per recipient
        - to_delete: list of certs to delete
        - best_for_fpr: dict mapping fpr -> list of emails
    """
    result = Classified(
        keep_email=[],
        keep_no_aka=[],
        keep_best_valid=[],
        keep_best_expired=[],
        to_delete=[],
        best_for_fpr={},
    )

    uncategorized = []

    # First pass: categorize keep_email and keep_no_aka
    for cert in certs:
        if not cert.emails:
            result.keep_no_aka.append(cert)
        elif keep_email in cert.emails:
            result.keep_email.append(cert)
        else:
            uncategorized.append(cert)

    # Second pass: find best cert per recipient email
    best_for_email = {}  # email -> Cert

    def best_key(cert: Cert) -> tuple[bool, datetime, str]:
        return (cert.is_valid, cert.not_after, cert.fpr)

    for cert in uncategorized:
        for email in cert.emails:
            current_best = best_for_email.get(email)
            if current_best is None or best_key(cert) > best_key(current_best):
                best_for_email[email] = cert

    # Build reverse map: cert_fpr -> [emails it's best for]
    best_for_fpr = {}  # fpr -> [emails]
    for email, cert in best_for_email.items():
        if cert.fpr not in best_for_fpr:
            best_for_fpr[cert.fpr] = []
        best_for_fpr[cert.fpr].append(email)
    result.best_for_fpr = best_for_fpr

    # Mark best certs as keep_best_valid or keep_best_expired
    for cert in uncategorized:
        if cert.fpr in best_for_fpr:
            if cert.is_valid:
                result.keep_best_valid.append(cert)
            else:
                result.keep_best_expired.append(cert)

    # Third pass: mark remaining expired as to_delete
    for cert in uncategorized:
        if cert.fpr not in best_for_fpr and not cert.is_valid:
            result.to_delete.append(cert)

    return result


def print_category(
    header: str,
    certs: list[Cert],
    category_type: str,
    best_for_fpr: dict[str, list[str]] | None = None,
):
    """
    Print a category of certificates with consistent formatting.

    Args:
        header: Section header
        certs: List of cert dicts
        category_type: One of "keep_email", "keep_no_aka", "keep_best_valid",
                       "keep_best_expired", "to_delete"
        best_for_fpr: Mapping from fpr to emails (for best-per-recipient categories)
    """
    if not certs:
        return

    print(f"\n=== {header} ===")

    best_for_fpr = best_for_fpr or {}

    def format_cert_line(
        cert: Cert,
        *,
        emails: str | None = None,
        expired_tag: str = "",
    ) -> str:
        line = f"valid until {cert.not_after}  fpr={cert.fpr}"
        if emails is not None:
            line += f"  aka={emails}"
        return line + expired_tag

    def format_keep_no_aka(cert: Cert) -> str:
        expired_tag = " [EXPIRED]" if not cert.is_valid else ""
        return format_cert_line(cert, expired_tag=expired_tag)

    def format_keep_best_valid(cert: Cert) -> str:
        emails = ", ".join(best_for_fpr.get(cert.fpr, []))
        return format_cert_line(cert, emails=emails)

    def format_keep_best_expired(cert: Cert) -> str:
        emails = ", ".join(best_for_fpr.get(cert.fpr, []))
        return format_cert_line(cert, emails=emails, expired_tag=" [EXPIRED]")

    def format_default(cert: Cert) -> str:
        emails = ", ".join(cert.emails)
        expired_tag = " [EXPIRED]" if not cert.is_valid else ""
        return format_cert_line(cert, emails=emails, expired_tag=expired_tag)

    formatters = {
        "keep_no_aka": format_keep_no_aka,
        "keep_best_valid": format_keep_best_valid,
        "keep_best_expired": format_keep_best_expired,
    }
    formatter = formatters.get(category_type, format_default)

    for cert in certs:
        print(formatter(cert))


def process_deletions(
    to_delete: list[Cert],
    simulate: bool,
    verbose: bool,
    prune_email: str | None,
) -> int:
    """
    Process deletion of expired certificates.

    Args:
        to_delete: List of certs to delete
        simulate: If True, only print what would be deleted
        verbose: If True, print section header
        prune_email: Limit to this email

    Returns:
        Number of certificates actually deleted (0 if simulate)
    """
    if not to_delete:
        return 0

    if verbose:
        print("\n=== Deleting certificates ===")

    deleted_count = 0

    for cert in to_delete:
        if prune_email and prune_email not in cert.emails:
            continue
        emails = ", ".join(cert.emails)
        msg = f"deleting expired: valid until {cert.not_after}  fpr={cert.fpr}  aka={emails}"

        if simulate:
            print("[SIMULATE] " + msg)
        else:
            print(msg)
            delete_cert(cert.fpr)
            deleted_count += 1

    return deleted_count


def print_summary(
    classified: Classified,
    deleted_count: int,
    simulate: bool,
):
    """
    Print summary statistics.

    Args:
        classified: Dict with categorized cert lists
        deleted_count: Number of certs actually deleted
        simulate: Whether in simulate mode
    """

    def count_expired(certs: list[Cert]) -> int:
        return sum(1 for c in certs if not c.is_valid)

    # Calculate stats
    total = (
        len(classified.keep_email)
        + len(classified.keep_no_aka)
        + len(classified.keep_best_valid)
        + len(classified.keep_best_expired)
        + len(classified.to_delete)
    )

    expired_keep_email = count_expired(classified.keep_email)
    expired_keep_no_aka = count_expired(classified.keep_no_aka)
    # keep_best_expired are all expired by definition
    expired_keep_best = len(classified.keep_best_expired)

    valid_keep_email = len(classified.keep_email) - expired_keep_email
    valid_keep_no_aka = len(classified.keep_no_aka) - expired_keep_no_aka
    valid_keep_best = len(classified.keep_best_valid)
    total_valid_kept = valid_keep_email + valid_keep_no_aka + valid_keep_best

    total_expired_found = (
        expired_keep_email
        + expired_keep_no_aka
        + expired_keep_best
        + len(classified.to_delete)
    )

    summary = f"""

Parsed cert entries:                      {total}
Expired entries found:                    {total_expired_found}
Expired kept (keep-email):                {expired_keep_email}
Expired kept (best-per-email):            {expired_keep_best}
Expired kept (no aka):                    {expired_keep_no_aka}
Valid kept (keep-email):                  {valid_keep_email}
Valid kept (best-per-email):              {valid_keep_best}
Valid kept (no aka):                      {valid_keep_no_aka}
Valid kept (total):                       {total_valid_kept}
Expired deleted:                          {deleted_count}{" (simulate mode)" if simulate else ""}
Entries with no aka (never delete):       {len(classified.keep_no_aka)}
"""
    print(summary)


def main():
    ap = argparse.ArgumentParser(
        formatter_class=argparse.RawDescriptionHelpFormatter,
        description="""Prune expired S/MIME certificates from your gpgsm keybox.

This tool helps clean up expired certificates while ensuring you can still
communicate with all recipients. It removes expired certificates with the
following safety rules:

  1. All certificates for --keep-email are preserved (typically your own email)
  2. At least one certificate per recipient email is kept (prefers valid over
     expired, then newest by expiration date)
  3. Certificates without an 'aka:' email field are never deleted

Use this when your gpgsm keybox becomes cluttered with expired certificates
from the same recipients. The tool ensures you maintain communication capability
while removing redundant expired certificates.

Use --simulate first to preview what would be deleted before actual deletion.

Use --prune-email to limit deletion of expired certificates to this recipient.
        """,
    )
    ap.add_argument(
        "-k",
        "--keep-email",
        required=True,
        help="Email address for which ALL certs are kept (e.g. your own).",
    )
    ap.add_argument(
        "-p",
        "--prune-email",
        help="Limit pruning to this email.",
    )
    ap.add_argument(
        "-s",
        "--simulate",
        action="store_true",
        help="Print what would be deleted, but do not delete anything.",
    )
    ap.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Print detailed information about kept certificates, especially expired ones.",
    )
    args = ap.parse_args()

    keep_email = normalize_email(args.keep_email)
    prune_email = (
        normalize_email(args.prune_email) if args.prune_email else None
    )
    now = datetime.now(timezone.utc)

    # Parse gpgsm output
    certs = parse_gpgsm_certs(now, keep_email)

    # Classify certificates into categories
    classified = classify_certs(certs, keep_email)

    # Verbose output - show what we're keeping
    if args.verbose:
        print_category(
            "Certificates kept for --keep-email",
            classified.keep_email,
            "keep_email",
        )
        print_category(
            "Certificates kept as best for recipient (valid)",
            classified.keep_best_valid,
            "keep_best_valid",
            classified.best_for_fpr,
        )
        print_category(
            "Certificates kept as best for recipient (expired - no valid alternative)",
            classified.keep_best_expired,
            "keep_best_expired",
            classified.best_for_fpr,
        )
        print_category(
            "Certificates kept (no aka - safety)",
            classified.keep_no_aka,
            "keep_no_aka",
        )

    # Process deletions
    deleted_count = process_deletions(
        classified.to_delete,
        args.simulate,
        args.verbose,
        prune_email,
    )

    # Print summary
    print_summary(classified, deleted_count, args.simulate)


if __name__ == "__main__":
    main()
